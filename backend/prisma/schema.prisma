generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  role              String    @default("user")
  enabled           Boolean   @default(true)
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  assetRecords      AssetRecord[]
  transactions      Transaction[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  inventoryPlan     InventoryPlan?
  adminAuditLogs    AuditLog[]  @relation("AdminAuditLogs")
  targetAuditLogs   AuditLog[]  @relation("TargetAuditLogs")
  healthConfig      HealthConfig?
  healthScores      HealthScore[]

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AssetRecord {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  date              DateTime @db.Date
  cash              Decimal  @db.Decimal(15, 2)
  longTermInvest    Decimal  @map("long_term_invest") @db.Decimal(15, 2)
  stableBond        Decimal  @map("stable_bond") @db.Decimal(15, 2)
  total             Decimal  @db.Decimal(15, 2)
  note              String?  @db.VarChar(100)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("asset_records")
}

enum TransactionDirection {
  INCOME
  EXPENSE
  TRANSFER
}

enum AssetCategory {
  CASH
  LONG_TERM_INVEST
  STABLE_BOND
}

model Transaction {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  date        DateTime             @db.Date
  amount      Decimal              @db.Decimal(15, 2)
  direction   TransactionDirection
  category    AssetCategory
  counterparty String              @db.VarChar(100)
  note        String?              @db.VarChar(200)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, direction])
  @@index([userId, category])
  @@map("transactions")
}

enum NotificationType {
  ACCOUNT_LOCKED
  NEW_DEVICE_LOGIN
  ASSET_TARGET_REACHED
  INVENTORY_REMINDER
  SYSTEM_NOTICE
  ADMIN_ACTION
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String           @db.VarChar(200)
  content   String           @db.Text
  data      String?          @db.Text
  read      Boolean          @default(false)
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime?        @map("expires_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("notifications")
}

enum InventoryCycleType {
  WEEKLY
  MONTHLY
  CUSTOM
}

model InventoryPlan {
  id                String              @id @default(uuid())
  userId            String              @unique @map("user_id")
  cycleType         InventoryCycleType  @default(MONTHLY) @map("cycle_type")
  customIntervalDays Int?               @map("custom_interval_days")
  weeklyDayOfWeek   Int?                @map("weekly_day_of_week")
  monthlyDayOfMonth Int?                @map("monthly_day_of_month")
  reminderDaysBefore Int               @default(3) @map("reminder_days_before")
  reminderEnabled   Boolean             @default(true) @map("reminder_enabled")
  skipHolidays      Boolean             @default(false) @map("skip_holidays")
  lastInventoryDate DateTime?           @map("last_inventory_date")
  lastNotifiedDate  DateTime?           @map("last_notified_date")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("inventory_plans")
}

enum AuditAction {
  ENABLE_USER
  DISABLE_USER
  UNLOCK_USER
  CHANGE_ROLE
  FORCE_LOGOUT
}

model AuditLog {
  id          String      @id @default(uuid())
  adminId     String      @map("admin_id")
  adminEmail  String      @map("admin_email")
  targetUserId String     @map("target_user_id")
  targetUserEmail String  @map("target_user_email")
  action      AuditAction
  detail      String?
  createdAt   DateTime    @default(now()) @map("created_at")

  admin       User        @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser  User        @relation("TargetAuditLogs", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum HealthDimension {
  EMERGENCY_RESERVE
  ASSET_ALLOCATION
  GROWTH_STABILITY
  INVENTORY_TIMELINESS
}

model HealthConfig {
  id                          String   @id @default(uuid())
  userId                      String   @unique @map("user_id")
  monthlyExpense              Decimal  @map("monthly_expense") @db.Decimal(15, 2)
  targetCashRatio             Decimal  @map("target_cash_ratio") @db.Decimal(5, 4)
  targetLongTermInvestRatio   Decimal  @map("target_long_term_invest_ratio") @db.Decimal(5, 4)
  targetStableBondRatio       Decimal  @map("target_stable_bond_ratio") @db.Decimal(5, 4)
  emergencyReserveWeight      Decimal  @map("emergency_reserve_weight") @db.Decimal(5, 4)
  assetAllocationWeight       Decimal  @map("asset_allocation_weight") @db.Decimal(5, 4)
  growthStabilityWeight       Decimal  @map("growth_stability_weight") @db.Decimal(5, 4)
  inventoryTimelinessWeight   Decimal  @map("inventory_timeliness_weight") @db.Decimal(5, 4)
  volatilityWindowMonths      Int      @map("volatility_window_months") @default(6)
  minEmergencyReserveMonths   Int      @map("min_emergency_reserve_months") @default(3)
  idealEmergencyReserveMonths Int      @map("ideal_emergency_reserve_months") @default(6)
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("health_configs")
}

model HealthScore {
  id                          String   @id @default(uuid())
  userId                      String   @map("user_id")
  totalScore                  Decimal  @map("total_score") @db.Decimal(5, 2)
  emergencyReserveScore       Decimal  @map("emergency_reserve_score") @db.Decimal(5, 2)
  assetAllocationScore        Decimal  @map("asset_allocation_score") @db.Decimal(5, 2)
  growthStabilityScore        Decimal  @map("growth_stability_score") @db.Decimal(5, 2)
  inventoryTimelinessScore    Decimal  @map("inventory_timeliness_score") @db.Decimal(5, 2)
  emergencyReserveWeight      Decimal  @map("emergency_reserve_weight") @db.Decimal(5, 4)
  assetAllocationWeight       Decimal  @map("asset_allocation_weight") @db.Decimal(5, 4)
  growthStabilityWeight       Decimal  @map("growth_stability_weight") @db.Decimal(5, 4)
  inventoryTimelinessWeight   Decimal  @map("inventory_timeliness_weight") @db.Decimal(5, 4)
  emergencyReserveSuggestion  String   @map("emergency_reserve_suggestion") @db.VarChar(500)
  assetAllocationSuggestion   String   @map("asset_allocation_suggestion") @db.VarChar(500)
  growthStabilitySuggestion   String   @map("growth_stability_suggestion") @db.VarChar(500)
  inventoryTimelinessSuggestion String  @map("inventory_timeliness_suggestion") @db.VarChar(500)
  dataQuality                 String   @map("data_quality") @db.VarChar(20)
  dataQualityNote             String?  @map("data_quality_note") @db.VarChar(500)
  calculatedAt                DateTime @map("calculated_at")
  createdAt                   DateTime @default(now()) @map("created_at")

  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, calculatedAt])
  @@map("health_scores")
}
